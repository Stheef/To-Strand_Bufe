{% include 'bufe/admin/admin_header.html.twig' %}
<section class="main-content">
  <a class='btn second-color mb-2' href='' data-toggle="modal" data-target="#newModal"> <i
      class="fa-solid fa-circle-plus"></i> Új admin</a>
  <div class="row row-cols-1 row-cols-md-3 g-4">
  {% for admin in admins %}
  <div class="col">
    <div class="card h-100">
      <div class="card-body">
        <h5 class="card-title">{{admin.user_name}}</h5>
        <p class="card-text">{{admin.email}}</p>
        <a class='btn btn-warning' href='itemEdit/{{product.id}}' data-toggle="modal" data-target="#deleteModal"> <i class="fa-solid fa-edit"></i> Módosít</a>
        <a class='btn btn-danger' href='itemDelete/{{product.id}}' data-toggle="modal" data-target="#deleteModal"> <i class="fa-solid fa-trash"></i> Töröl</a>
      </div>
    </div>
  </div>
  {% endfor %}
</div>

</section>
</section>

<div class="modal fade" id="editModal">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h4 class="modal-title">Admin módosítás</h4>
        <button type="button" class="close" data-dismiss="modal">&times;</button>
      </div>
      <div class="modal-body">
        <form action="update.php" id="edit-form">
          <input class="form-control" type="hidden" value="{{ admin.id }}" name="id">
          <div class="form-group">
            <label for="name">Név</label>
            <input class="form-control" type="text" value="{{ admin.user_name }}" name="name" id="name">
          </div>
          <div class="form-group">
            <label for="exampleInputPassword1">Jelszó</label>
            <input type="password" class="form-control" id="exampleInputPassword1">
          </div>
          <div class="form-group">
            <label for="exampleInputPassword1">Jelszó újra</label>
            <input type="password" class="form-control" id="exampleInputPassword1">
          </div>
          <button type="button" class="btn btn-success" name="insert" id="insert"><i
              class="fa-solid fa-floppy-disk"></i> Mentés</button>
          <button type="button" class="btn btn-danger float-right" data-dismiss="modal"><i
              class="fa-solid fa-xmark"></i> Mégse</button>
        </form>
      </div>
    </div>
  </div>
</div>

<div class="modal fade" id="newModal">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h4 class="modal-title">Új admin</h4>
        <button type="button" class="close" data-dismiss="modal">&times;</button>
      </div>
      <div class="modal-body">
        <form action="update.php" id="edit-form">
          <input class="form-control" type="hidden" value="{{ admin.id }}" name="id">
          <div class="form-group">
            <label for="name">Név*</label>
            <input class="form-control" type="text" value="{{ admin.felhasznalo_nev }}" name="name" id="name">
          </div>
          <div class="form-group">
            <label for="exampleInputPassword1">Jelszó*</label>
            <input type="password" class="form-control" id="exampleInputPassword1">
          </div>
          <div class="form-group">
            <label for="exampleInputPassword1">Jelszó újra*</label>
            <input type="password_again" class="form-control" id="exampleInputPassword1">
          </div>
          <button type="button" class="btn btn-success" name="insert" id="insert"><i class="fa-solid fa-floppy-disk"></i> Mentés</button>
          <button type="button" class="btn btn-danger float-right" data-dismiss="modal"><i class="fa-solid fa-xmark"></i> Mégse</button>
        </form>
      </div>
    </div>
  </div>
</div>

<div class="modal fade" id="deleteModal">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-body">
        <form action="update.php" id="edit-form">
          <input type="hidden" value="{{admin.id}}" name="id">
          <div class="text-center">
            <i class="fa-regular fa-circle-xmark rcross"></i>
            <p>Biztosan törölni szeretné {{admin.user_name}} nevű admin fiókot?</p>
          </div>
          <button type="button" class="btn btn-warning" data-dismiss="modal" name="insert" id="insert"><i
              class="fa-solid fa-arrow-left"></i> Mégse</button>
          <button type="button" class="btn btn-danger float-right"><i
              class="fa-solid fa-xmark"></i> Törlés</button>
        </form>
      </div>
    </div>
  </div>
</div>
{% include 'bufe/admin/admin_footer.html.twig' %}